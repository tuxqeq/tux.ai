# Copy to .env.local for local development
# Never commit .env.local to git

# Server master key — encrypts stored dataset AES keys at rest.
# Must be exactly 32 ASCII chars (pad with ! if needed).
MASTER_KEY=CHANGE_ME_MASTER_KEY_32_bytes!!!

# JWT signing secret — must be kept private.
JWT_SECRET=CHANGE_ME_in_production_32_chars!!

# Ollama endpoint (default: local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=tux-ai-chat

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://tuxai:tuxai@localhost:5432/tuxai

# Redis
REDIS_URL=redis://localhost:6379

# PII model path (relative to project root).
# Change to models/pii_model_advanced or models/pii_model_large if you have those.
MODEL_PATH=models/pii_model_v2
